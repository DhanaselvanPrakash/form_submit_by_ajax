<section class="flex gap-5 flex-wrap">
  <% @todos.each do |todo| %>
    <div class="card border p-5 rounded w-1/5">
      <div class="my-2">
        <p class="font-bold">Title</p>
        <p><%= todo.title %></p>
      </div>
      <div class="my-2">
        <p class="font-bold">Status</p>
        <p><%= todo.status %></p>
      </div>
      <div class="my-2">
        <p class="font-bold">Deadline</p>
        <p><%= todo.deadline %></p>
      </div>
      <div class="my-2">
        <!-- <button id="todo_<%= todo.id %>" class="delete-btn px-2 py-1 bg-red-500 text-white" value="<%= todo.id %>">Delete This</button> -->
         <%= link_to "Show this", todo_path(todo.id) %>
      </div>
    </div>
  <% end %>
</section>